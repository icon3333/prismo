# Repo-root .dockerignore for classic (non-BuildKit) docker builds.
# Mirrors deployment/Dockerfile.dockerignore — BuildKit reads that per-Dockerfile
# ignore file, but legacy builders only honor this root .dockerignore. Without
# it, a legacy build bakes the live SQLite DB and .env into image layers.
# Keep the two files in sync.

# Git files
.git
.gitignore
.gitattributes

# Frontend (served separately; backend image is the Flask API only)
frontend/

# Documentation
*.md
docs/

# Test files
tests/
.pytest_cache/
.coverage
htmlcov/

# Environment, secrets and backup files
.env
.env.backup.*
.env.local
.env.development
.env.test

# Database and instance directories (mounted as a volume at runtime;
# never bake the live SQLite DB into image layers)
instance/
*.db

# Python cache and virtual environments
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.tox/
.cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
temp/

# Node modules (if any)
node_modules/

# Build artifacts
build/
dist/
*.egg-info/
